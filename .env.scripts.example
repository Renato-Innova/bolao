# ─────────────────────────────────────────────────────────────────
# Variáveis para os scripts de cópia/restore prod ↔ staging
# Copie este arquivo para .env.scripts e preencha com as connection
# strings reais. NÃO commite o .env.scripts (já está no .gitignore).
#
# Uso: node --env-file=.env.scripts scripts/copy-prod-to-staging.js
# ─────────────────────────────────────────────────────────────────

PROD_DATABASE_URL=postgresql://postgres:SENHA@db.SEU_PROJETO_PROD.supabase.co:5432/postgres
STAGING_DATABASE_URL=postgresql://postgres:SENHA@db.SEU_PROJETO_STAGING.supabase.co:5432/postgres
